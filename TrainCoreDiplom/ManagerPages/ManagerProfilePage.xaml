<Page x:Class="TrainCoreDiplom.ManagerPages.ManagerProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Мой профиль"
      MaxHeight="1080" MaxWidth="1920"
      MinHeight="500" MinWidth="800"
      Background="#F5F7FA">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Мой профиль" FontSize="24" FontWeight="Bold" Foreground="#FF9800"/>
                <Button Grid.Column="1" Content="← Назад" Style="{StaticResource SecondaryButtonStyle}" Height="40" Width="100" Click="BackButton_Click"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="30">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Логин:" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="LoginText" FontSize="16" Margin="10"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Email:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,10"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="EmailText" FontSize="16" Margin="10,10"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Роль:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,10"/>
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="RoleText" FontSize="16" Foreground="#FF9800" FontWeight="Bold" Margin="10,10"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Последний вход:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,10"/>
                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="LastLoginText" FontSize="14" Foreground="#757575" Margin="10,10"/>
            </Grid>
        </Border>
    </Grid>
</Page>