<Page x:Class="TrainCoreDiplom.ManagerPages.ManagerSchedulePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:System="clr-namespace:System;assembly=mscorlib"
      Title="Управление расписанием"
      MaxHeight="1080" MaxWidth="1920"
      MinHeight="600" MinWidth="900"
      Background="#F5F7FA">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0"
                Background="White"
                CornerRadius="12"
                Padding="20"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Управление расписанием"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#FF9800"/>

                <Button Grid.Column="1"
                        Content="➕ Добавить рейс"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Height="40"
                        Width="140"
                        Margin="0,0,10,0"
                        Click="AddSchedule_Click"/>

                <Button Grid.Column="2"
                        Content="← Назад"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Height="40"
                        Width="100"
                        Click="BackButton_Click"/>
            </Grid>
        </Border>

        <!-- Фильтры -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="12"
                Padding="20"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Поезд" FontSize="12" Foreground="#757575"/>
                    <ComboBox x:Name="TrainFilterComboBox"
                              Style="{StaticResource ModernComboBoxStyle}"
                              SelectionChanged="FilterChanged"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="10,0">
                    <TextBlock Text="Маршрут" FontSize="12" Foreground="#757575"/>
                    <ComboBox x:Name="RouteFilterComboBox"
                              Style="{StaticResource ModernComboBoxStyle}"
                              SelectionChanged="FilterChanged"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="10,0,0,0">
                    <TextBlock Text="Дата" FontSize="12" Foreground="#757575"/>
                    <DatePicker x:Name="DateFilterPicker"
                                Style="{StaticResource ModernDatePickerStyle}"
                                SelectedDate="{x:Static System:DateTime.Today}"/>
                </StackPanel>

                <Button Grid.Column="3"
                        Content="Сбросить"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Height="45"
                        Width="100"
                        Margin="20,20,0,0"
                        Click="ResetFilter_Click"/>
            </Grid>
        </Border>

        <!-- Таблица расписания -->
        <Border Grid.Row="2"
                Background="White"
                CornerRadius="12"
                Padding="20">
            <DataGrid x:Name="ScheduleGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      RowHeight="40"
                      Background="Transparent"
                      BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding ID_Schedule}" Width="50"/>
                    <DataGridTextColumn Header="Поезд" Binding="{Binding TrainNumber}" Width="120"/>
                    <DataGridTextColumn Header="Маршрут" Binding="{Binding RouteName}" Width="250"/>
                    <DataGridTextColumn Header="Дата отправления" Binding="{Binding DepartureDate}" Width="120"/>
                    <DataGridTextColumn Header="Время отправления" Binding="{Binding DepartureTime}" Width="100"/>
                    <DataGridTextColumn Header="Дата прибытия" Binding="{Binding ArrivalDate}" Width="120"/>
                    <DataGridTextColumn Header="Время прибытия" Binding="{Binding ArrivalTime}" Width="100"/>
                    <DataGridTextColumn Header="Свободно мест" Binding="{Binding FreeSeats}" Width="80"/>
                    <DataGridTemplateColumn Header="Действия" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="✏" Width="30" Height="30" Margin="2"
                                            Click="EditSchedule_Click" Tag="{Binding ID_Schedule}"/>
                                    <Button Content="🗑" Width="30" Height="30" Margin="2"
                                            Click="DeleteSchedule_Click" Tag="{Binding ID_Schedule}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>