<Page x:Class="TrainCoreDiplom.ManagerPages.ManagerDashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Панель менеджера"
      MaxHeight="1080" MaxWidth="1920"
      MinHeight="700" MinWidth="1000"
      Background="#F5F7FA">

    <Page.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FFF3E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левое меню -->
        <Border Grid.Column="0"
                Background="White"
                CornerRadius="12"
                Padding="0"
                Margin="0,0,20,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Профиль менеджера -->
                <Border Grid.Row="0"
                        Background="#FF9800"
                        CornerRadius="12,12,0,0"
                        Padding="20">
                    <StackPanel>
                        <TextBlock Text="👔 Менеджер"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock x:Name="ManagerNameText"
                                   Text="Manager"
                                   Foreground="White"
                                   Opacity="0.9"
                                   FontSize="14"/>
                    </StackPanel>
                </Border>

                <!-- Пункты меню (только доступные) -->
                <StackPanel Grid.Row="1" Margin="10">
                    <Button Content="📊 Главная"
                            Style="{StaticResource MenuButtonStyle}"
                            Click="Dashboard_Click"/>

                    <Button Content="🚂 Поезда (просмотр)"
                            Style="{StaticResource MenuButtonStyle}"
                            Click="Trains_Click"/>

                    <Button Content="📅 Расписание"
                            Style="{StaticResource MenuButtonStyle}"
                            Click="Schedule_Click"/>

                    <Button Content="📈 Отчеты"
                            Style="{StaticResource MenuButtonStyle}"
                            Click="Reports_Click"/>

                    <Button Content="👤 Мой профиль"
                            Style="{StaticResource MenuButtonStyle}"
                            Click="Profile_Click"/>
                </StackPanel>

                <!-- Выход -->
                <Button Grid.Row="2"
                        Content="🚪 Выйти"
                        Style="{StaticResource MenuButtonStyle}"
                        Margin="10"
                        Click="Logout_Click"/>
            </Grid>
        </Border>

        <!-- Правая часть - контент -->
        <ScrollViewer Grid.Column="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <!-- Приветствие -->
                <Border Background="White"
                        CornerRadius="12"
                        Padding="20"
                        Margin="0,0,0,20">
                    <TextBlock x:Name="WelcomeText" 
                               Text="Добро пожаловать!"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#FF9800"/>
                </Border>

                <!-- Статистика (только для просмотра) -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <!-- Активные поезда сегодня -->
                    <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="20" Margin="5">
                        <StackPanel>
                            <TextBlock Text="Активных поездов сегодня" 
                                       FontSize="14" 
                                       Foreground="#757575"/>
                            <TextBlock x:Name="ActiveTrainsText" 
                                       FontSize="32" 
                                       FontWeight="Bold" 
                                       Foreground="#FF9800" 
                                       Text="0"/>
                        </StackPanel>
                    </Border>

                    <!-- Продажи за сегодня -->
                    <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="20" Margin="5">
                        <StackPanel>
                            <TextBlock Text="Продажи сегодня" 
                                       FontSize="14" 
                                       Foreground="#757575"/>
                            <TextBlock x:Name="TodaySalesText" 
                                       FontSize="32" 
                                       FontWeight="Bold" 
                                       Foreground="#4CAF50" 
                                       Text="0"/>
                        </StackPanel>
                    </Border>

                    <!-- Выручка за сегодня -->
                    <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="20" Margin="5">
                        <StackPanel>
                            <TextBlock Text="Выручка сегодня" 
                                       FontSize="14" 
                                       Foreground="#757575"/>
                            <TextBlock x:Name="TodayRevenueText" 
                                       FontSize="32" 
                                       FontWeight="Bold" 
                                       Foreground="#1E88E5" 
                                       Text="0 ₽"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Расписание на сегодня -->
                <Border Background="White"
                        CornerRadius="12"
                        Padding="20"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="📅 Расписание на сегодня"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#FF9800"
                                   Margin="0,0,0,15"/>

                        <DataGrid x:Name="TodayScheduleGrid"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  RowHeight="35"
                                  Background="Transparent"
                                  BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Время" 
                                                    Binding="{Binding Time}"
                                                    Width="80"/>
                                <DataGridTextColumn Header="Поезд" 
                                                    Binding="{Binding Train}"
                                                    Width="120"/>
                                <DataGridTextColumn Header="Маршрут" 
                                                    Binding="{Binding Route}"
                                                    Width="250"/>
                                <DataGridTextColumn Header="Свободно мест" 
                                                    Binding="{Binding FreeSeats}"
                                                    Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- Последние операции (только просмотр) -->
                <Border Background="White"
                        CornerRadius="12"
                        Padding="20">
                    <StackPanel>
                        <TextBlock Text="📋 Последние продажи"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#FF9800"
                                   Margin="0,0,0,15"/>

                        <DataGrid x:Name="RecentSalesGrid"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  RowHeight="35"
                                  Background="Transparent"
                                  BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Время" 
                                                    Binding="{Binding Time}"
                                                    Width="80"/>
                                <DataGridTextColumn Header="Поезд" 
                                                    Binding="{Binding Train}"
                                                    Width="120"/>
                                <DataGridTextColumn Header="Маршрут" 
                                                    Binding="{Binding Route}"
                                                    Width="250"/>
                                <DataGridTextColumn Header="Сумма" 
                                                    Binding="{Binding Amount}"
                                                    Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>