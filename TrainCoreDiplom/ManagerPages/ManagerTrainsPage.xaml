<Page x:Class="TrainCoreDiplom.ManagerPages.ManagerTrainsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Просмотр поездов"
      MaxHeight="1080" MaxWidth="1920"
      MinHeight="600" MinWidth="900"
      Background="#F5F7FA">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0"
                Background="White"
                CornerRadius="12"
                Padding="20"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Просмотр поездов"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#FF9800"/>

                <Button Grid.Column="1"
                        Content="← Назад"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Height="40"
                        Width="100"
                        Click="BackButton_Click"/>
            </Grid>
        </Border>

        <!-- Таблица поездов (только для чтения) -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="12"
                Padding="20">
            <DataGrid x:Name="TrainsGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      RowHeight="40"
                      Background="Transparent"
                      BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Номер поезда" 
                                        Binding="{Binding Number_train}"
                                        Width="120"/>
                    <DataGridTextColumn Header="Название" 
                                        Binding="{Binding Name_train}"
                                        Width="200"/>
                    <DataGridTextColumn Header="Тип поезда" 
                                        Binding="{Binding TypeName}"
                                        Width="150"/>
                    <DataGridTextColumn Header="Кол-во вагонов" 
                                        Binding="{Binding WagonsCount}"
                                        Width="120"/>
                    <DataGridTextColumn Header="Всего мест" 
                                        Binding="{Binding TotalSeats}"
                                        Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>