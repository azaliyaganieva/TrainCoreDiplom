<Page x:Class="TrainCoreDiplom.ManagerPages.ManagerReportsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Отчеты"
      MaxHeight="1080" MaxWidth="1920"
      MinHeight="600" MinWidth="900"
      Background="#F5F7FA">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Отчеты" FontSize="24" FontWeight="Bold" Foreground="#FF9800"/>
                <Button Grid.Column="1" Content="← Назад" Style="{StaticResource SecondaryButtonStyle}" Height="40" Width="100" Click="BackButton_Click"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Период:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <DatePicker Grid.Column="1" x:Name="StartDatePicker" Style="{StaticResource ModernDatePickerStyle}"/>
                <TextBlock Grid.Column="2" Text="—" FontSize="16" VerticalAlignment="Center" Margin="10,0"/>
                <DatePicker Grid.Column="3" x:Name="EndDatePicker" Style="{StaticResource ModernDatePickerStyle}"/>
                <ComboBox Grid.Column="4" x:Name="ReportTypeComboBox" Style="{StaticResource ModernComboBoxStyle}" Width="200" Margin="20,0,0,0">
                    <ComboBoxItem Content="Продажи по дням" IsSelected="True"/>
                    <ComboBoxItem Content="Продажи по маршрутам"/>
                    <ComboBoxItem Content="Продажи по типам вагонов"/>
                </ComboBox>
                <Button Grid.Column="5" Content="Сформировать" Style="{StaticResource PrimaryButtonStyle}" Height="45" Width="140" Click="GenerateReport_Click"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="20">
            <DataGrid x:Name="ReportDataGrid" AutoGenerateColumns="True" IsReadOnly="True" RowHeight="35"
                      Background="Transparent" BorderThickness="0"/>
        </Border>
    </Grid>
</Page>