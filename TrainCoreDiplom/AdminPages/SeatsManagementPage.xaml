<Page x:Class="TrainCoreDiplom.AdminPages.SeatsManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Управление местами"
      MaxHeight="1080" MaxWidth="1920"
      MinHeight="600" MinWidth="800"
      Background="#F5F7FA">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0"
                Background="White"
                CornerRadius="12"
                Padding="20"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="TitleText"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#1E88E5"/>
                    <TextBlock x:Name="WagonInfoText"
                               FontSize="14"
                               Foreground="#757575"
                               Margin="0,5,0,0"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="← Назад"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Height="40"
                        Width="100"
                        Click="BackButton_Click"/>
            </Grid>
        </Border>

        <!-- Информация о вагоне -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="12"
                Padding="15"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                           Text="🚆" 
                           FontSize="32" 
                           Margin="0,0,20,0"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1">
                    <TextBlock x:Name="WagonDetailsText"
                               FontSize="14"
                               TextWrapping="Wrap"/>
                    <TextBlock x:Name="SeatsStatsText"
                               FontSize="12"
                               Foreground="#1E88E5"
                               Margin="0,5,0,0"/>
                </StackPanel>

                <Button Grid.Column="2"
                        Content="➕ Добавить место"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Height="40"
                        Width="140"
                        Click="AddSeat_Click"/>
            </Grid>
        </Border>

        <!-- Таблица мест -->
        <Border Grid.Row="2"
                Background="White"
                CornerRadius="12"
                Padding="20">
            <DataGrid x:Name="SeatsGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      RowHeight="40"
                      Background="Transparent"
                      BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" 
                                        Binding="{Binding ID_Seat}"
                                        Width="50"/>
                    <DataGridTextColumn Header="Номер места" 
                                        Binding="{Binding Number_seats}"
                                        Width="100"/>
                    <DataGridTextColumn Header="Тип места" 
                                        Binding="{Binding Type_seats}"
                                        Width="120"/>
                    <DataGridCheckBoxColumn Header="Доступно" 
                                            Binding="{Binding IsAvailable}"
                                            Width="80"/>
                    <DataGridTextColumn Header="Цена" 
                                        Binding="{Binding Price}"
                                        Width="100"/>
                    <DataGridTextColumn Header="Характеристики" 
                                        Binding="{Binding Features}"
                                        Width="200"/>
                    <DataGridTemplateColumn Header="Действия" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="✏" 
                                            Width="30"
                                            Height="30"
                                            Margin="2"
                                            ToolTip="Редактировать"
                                            Click="EditSeat_Click"
                                            Tag="{Binding ID_Seat}"/>
                                    <Button Content="🗑" 
                                            Width="30"
                                            Height="30"
                                            Margin="2"
                                            ToolTip="Удалить"
                                            Click="DeleteSeat_Click"
                                            Tag="{Binding ID_Seat}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>