<Page x:Class="TrainCoreDiplom.AdminPages.UsersManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Управление пользователями"
      MaxHeight="1080" MaxWidth="1920"
      MinHeight="600" MinWidth="900">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0"
        Background="White"
        CornerRadius="12"
        Padding="20"
        Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                   Text="Управление пользователями"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="#1E88E5"/>

                <Button Grid.Column="1"
                Content="➕ Добавить пользователя"
                Style="{StaticResource PrimaryButtonStyle}"
                Height="40"
                Width="180"
                Margin="0,0,10,0"
                Click="AddUser_Click"/>

                <ComboBox Grid.Column="2"
                  x:Name="RoleFilterComboBox"
                  Style="{StaticResource ModernComboBoxStyle}"
                  Width="150"
                  Margin="0,0,10,0"
                  SelectionChanged="FilterChanged">
                    <ComboBoxItem Content="Все пользователи" IsSelected="True"/>
                    <ComboBoxItem Content="Администраторы"/>
                    <ComboBoxItem Content="Менеджеры"/>
                    <ComboBoxItem Content="Пользователи"/>
                </ComboBox>

                <!-- Кнопка назад -->
                <Button Grid.Column="3"
                Content="← Назад"
                Style="{StaticResource SecondaryButtonStyle}"
                Height="40"
                Width="100"
                Click="BackButton_Click"/>
            </Grid>
        </Border>
        <!-- Таблица пользователей -->
        <Border Grid.Row="1"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="12"
                Padding="20">
            <DataGrid x:Name="UsersGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      RowHeight="40"
                      Background="Transparent"
                      BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" 
                                        Binding="{Binding ID_User}"
                                        Width="50"/>
                    <DataGridTextColumn Header="Логин" 
                                        Binding="{Binding Login}"
                                        Width="120"/>
                    <DataGridTextColumn Header="Email" 
                                        Binding="{Binding Email}"
                                        Width="200"/>
                    <DataGridTextColumn Header="Роль" 
                                        Binding="{Binding RoleName}"
                                        Width="120"/>
                    <DataGridTextColumn Header="Последний вход" 
                                        Binding="{Binding LastLogin, StringFormat=dd.MM.yyyy HH:mm}"
                                        Width="150"/>
                    <DataGridCheckBoxColumn Header="Активен" 
                                            Binding="{Binding IsActive}"
                                            Width="80"/>
                    <DataGridTextColumn Header="Дата регистрации" 
                                        Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy}"
                                        Width="100"/>
                    <DataGridTemplateColumn Header="Действия" Width="200">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="✏" 
                                            Width="30"
                                            Height="30"
                                            Margin="2"
                                            Click="EditUser_Click"
                                            Tag="{Binding ID_User}"/>
                                    <Button Content="🔒" 
                                            Width="30"
                                            Height="30"
                                            Margin="2"
                                            Click="ToggleUserStatus_Click"
                                            Tag="{Binding ID_User}"/>
                                    <Button Content="👑" 
                                            Width="30"
                                            Height="30"
                                            Margin="2"
                                            Click="ChangeRole_Click"
                                            Tag="{Binding ID_User}"/>
                                    <Button Content="📊" 
                                            Width="30"
                                            Height="30"
                                            Margin="2"
                                            Click="ViewUserHistory_Click"
                                            Tag="{Binding ID_User}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>