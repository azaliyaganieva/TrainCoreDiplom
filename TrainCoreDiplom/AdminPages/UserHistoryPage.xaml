<Page x:Class="TrainCoreDiplom.AdminWindows.UserHistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="История пользователя"
      Background="#F5F7FA">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                CornerRadius="12"
                Padding="20"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           x:Name="UserNameText"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#1E88E5"/>

                <Button Grid.Column="1"
                        Content="← Назад"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Height="40"
                        Width="100"
                        Click="BackButton_Click"/>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="12"
                Padding="20">
            <DataGrid x:Name="TicketsGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      RowHeight="40"
                      Background="Transparent"
                      BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID билета" Binding="{Binding TicketId}" Width="80"/>
                    <DataGridTextColumn Header="Поезд" Binding="{Binding TrainName}" Width="120"/>
                    <DataGridTextColumn Header="Маршрут" Binding="{Binding Route}" Width="250"/>
                    <DataGridTextColumn Header="Дата" Binding="{Binding Date}" Width="100"/>
                    <DataGridTextColumn Header="Вагон/Место" Binding="{Binding Seat}" Width="120"/>
                    <DataGridTextColumn Header="Стоимость" Binding="{Binding Price}" Width="100"/>
                    <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>