<Page x:Class="TrainCoreDiplom.AdminPages.TrainsManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Управление поездами"
      MaxHeight="1080" MaxWidth="1920"
      MinHeight="600" MinWidth="900">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок с кнопками -->
        <Border Grid.Row="0"
                Background="White"
                CornerRadius="12"
                Padding="20"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Управление поездами"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#1E88E5"/>

                <Button Grid.Column="1"
                        Content="➕ Добавить поезд"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Height="40"
                        Width="140"
                        Margin="0,0,10,0"
                        Click="AddTrain_Click"/>

                <Button Grid.Column="2"
                        Content="↻ Обновить"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Height="40"
                        Width="100"
                        Margin="0,0,10,0"
                        Click="Refresh_Click"/>

                <!-- Кнопка назад -->
                <Button Grid.Column="3"
                        Content="← Назад"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Height="40"
                        Width="100"
                        Click="BackButton_Click"/>
            </Grid>
        </Border>

        <!-- Таблица поездов -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="12"
                Padding="20">
            <DataGrid x:Name="TrainsGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      RowHeight="45"
                      Background="Transparent"
                      BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" 
                                        Binding="{Binding ID_Train}"
                                        Width="50"/>
                    <DataGridTextColumn Header="Номер поезда" 
                                        Binding="{Binding Number_train}"
                                        Width="100"/>
                    <DataGridTextColumn Header="Название" 
                                        Binding="{Binding Name_train}"
                                        Width="200"/>
                    <DataGridTextColumn Header="Тип поезда" 
                                        Binding="{Binding TypeName}"
                                        Width="120"/>
                    <DataGridTextColumn Header="Кол-во вагонов" 
                                        Binding="{Binding WagonsCount}"
                                        Width="100"/>
                    <DataGridTextColumn Header="Всего мест" 
                                        Binding="{Binding TotalSeats}"
                                        Width="100"/>
                    <DataGridTemplateColumn Header="Действия" Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="✏" 
                                            Width="30"
                                            Height="30"
                                            Margin="2"
                                            ToolTip="Редактировать"
                                            Click="EditTrain_Click"
                                            Tag="{Binding ID_Train}"/>
                                    <Button Content="🗑" 
                                            Width="30"
                                            Height="30"
                                            Margin="2"
                                            ToolTip="Удалить"
                                            Click="DeleteTrain_Click"
                                            Tag="{Binding ID_Train}"/>
                                    <Button Content="⚙" 
                                            Width="30"
                                            Height="30"
                                            Margin="2"
                                            ToolTip="Управление вагонами"
                                            Click="ManageWagons_Click"
                                            Tag="{Binding ID_Train}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>