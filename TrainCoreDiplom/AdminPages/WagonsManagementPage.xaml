<Page x:Class="TrainCoreDiplom.AdminWindows.WagonsManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Управление вагонами"
      MaxHeight="1080" MaxWidth="1920"
      MinHeight="600" MinWidth="800"
      Background="#F5F7FA">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0"
                Background="White"
                CornerRadius="12"
                Padding="20"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="TitleText"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#1E88E5"/>
                    <TextBlock x:Name="TrainInfoText"
                               FontSize="14"
                               Foreground="#757575"
                               Margin="0,5,0,0"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="➕ Добавить вагон"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Height="40"
                        Width="140"
                        Margin="0,0,10,0"
                        Click="AddWagon_Click"/>

                <Button Grid.Column="2"
                        Content="← Назад"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Height="40"
                        Width="100"
                        Click="BackButton_Click"/>
            </Grid>
        </Border>

        <!-- Информация о поезде -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="12"
                Padding="15"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                           Text="🚂" 
                           FontSize="32" 
                           Margin="0,0,20,0"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1">
                    <TextBlock x:Name="TrainDetailsText"
                               FontSize="14"
                               TextWrapping="Wrap"/>
                    <TextBlock x:Name="WagonsCountText"
                               FontSize="12"
                               Foreground="#1E88E5"
                               Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Таблица вагонов -->
        <Border Grid.Row="2"
                Background="White"
                CornerRadius="12"
                Padding="20">
            <DataGrid x:Name="WagonsGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      RowHeight="45"
                      Background="Transparent"
                      BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" 
                                        Binding="{Binding ID_Wagon}"
                                        Width="50"/>
                    <DataGridTextColumn Header="Номер вагона" 
                                        Binding="{Binding Number_wagon}"
                                        Width="100"/>
                    <DataGridTextColumn Header="Тип вагона" 
                                        Binding="{Binding TypeName}"
                                        Width="150"/>
                    <DataGridTextColumn Header="Кол-во мест" 
                                        Binding="{Binding SeatsCount}"
                                        Width="100"/>
                    <DataGridTextColumn Header="Свободно мест" 
                                        Binding="{Binding FreeSeats}"
                                        Width="100"/>
                    <DataGridTextColumn Header="Цена (базовая)" 
                                        Binding="{Binding BasePrice}"
                                        Width="120"/>
                    <DataGridTemplateColumn Header="Действия" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="✏" 
                                            Width="30"
                                            Height="30"
                                            Margin="2"
                                            ToolTip="Редактировать"
                                            Click="EditWagon_Click"
                                            Tag="{Binding ID_Wagon}"/>
                                    <Button Content="🗑" 
                                            Width="30"
                                            Height="30"
                                            Margin="2"
                                            ToolTip="Удалить"
                                            Click="DeleteWagon_Click"
                                            Tag="{Binding ID_Wagon}"/>
                                    <Button Content="🪑" 
                                            Width="30"
                                            Height="30"
                                            Margin="2"
                                            ToolTip="Управление местами"
                                            Click="ManageSeats_Click"
                                            Tag="{Binding ID_Wagon}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>