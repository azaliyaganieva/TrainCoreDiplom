<Window x:Class="TrainCoreDiplom.AdminWindows.SeatEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование места"
        Height="550" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F7FA">

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1E88E5"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0"
                Background="#1E88E5"
                CornerRadius="8"
                Padding="15"
                Margin="0,0,0,20">
            <TextBlock x:Name="TitleText"
                       Text="Данные места"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Форма с прокруткой -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Border Background="White"
                    CornerRadius="8"
                    Padding="20">
                <StackPanel>
                    <TextBlock Text="Номер места" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="NumberTextBox" 
                             Style="{StaticResource ModernTextBoxStyle}" 
                             Margin="0,0,0,15"/>

                    <TextBlock Text="Тип места" Style="{StaticResource LabelStyle}"/>
                    <ComboBox x:Name="TypeComboBox" 
                              Style="{StaticResource ModernComboBoxStyle}" 
                              Margin="0,0,0,15">
                        <ComboBoxItem Content="Стандартное" IsSelected="True"/>
                        <ComboBoxItem Content="Боковое"/>
                        <ComboBoxItem Content="У окна"/>
                        <ComboBoxItem Content="У прохода"/>
                    </ComboBox>

                    <TextBlock Text="Цена" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="PriceTextBox" 
                             Style="{StaticResource ModernTextBoxStyle}" 
                             Margin="0,0,0,15"
                             Text="1000"/>

                    <CheckBox x:Name="IsAvailableCheckBox" 
                              Content="Место доступно для бронирования"
                              IsChecked="True"
                              Margin="0,5,0,15"
                              FontSize="12"/>

                    <Border Background="#F5F5F5"
                            CornerRadius="8"
                            Padding="10"
                            Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="Характеристики места будут определены автоматически"
                                       FontSize="11"
                                       Foreground="#757575"/>
                            <TextBlock Text="• Нечетные номера - нижние полки"
                                       FontSize="10"
                                       Foreground="#757575"
                                       Margin="0,5,0,2"/>
                            <TextBlock Text="• Четные номера - верхние полки"
                                       FontSize="10"
                                       Foreground="#757575"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,20,0,0">
            <Button Content="Отмена" 
                    Style="{StaticResource SecondaryButtonStyle}"
                    Width="100" Height="40"
                    Margin="0,0,10,0"
                    Click="CancelButton_Click"/>
            <Button Content="Сохранить" 
                    Style="{StaticResource PrimaryButtonStyle}"
                    Width="100" Height="40"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>