<Window x:Class="TrainCoreDiplom.AdminWindows.ScheduleEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование расписания"
        Height="650" Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F7FA">

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1E88E5"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0"
                Background="#1E88E5"
                CornerRadius="8"
                Padding="15"
                Margin="0,0,0,20">
            <TextBlock Text="Данные рейса"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Форма с прокруткой -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Border Background="White"
                    CornerRadius="8"
                    Padding="20">
                <StackPanel>
                    <TextBlock Text="Поезд" Style="{StaticResource LabelStyle}"/>
                    <ComboBox x:Name="TrainComboBox" 
                              Style="{StaticResource ModernComboBoxStyle}" 
                              Margin="0,0,0,15"
                              DisplayMemberPath="Number_train"
                              SelectedValuePath="ID_Train"/>

                    <TextBlock Text="Маршрут" Style="{StaticResource LabelStyle}"/>
                    <ComboBox x:Name="RouteComboBox" 
                              Style="{StaticResource ModernComboBoxStyle}" 
                              Margin="0,0,0,15"
                              DisplayMemberPath="Display"
                              SelectedValuePath="ID_Route"/>

                    <TextBlock Text="Дата отправления" Style="{StaticResource LabelStyle}"/>
                    <DatePicker x:Name="StartDatePicker" 
                                Style="{StaticResource ModernDatePickerStyle}" 
                                Margin="0,0,0,15"
                                SelectedDate="{Binding StartDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Время отправления (ЧЧ:ММ)" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="StartTimeTextBox" 
                             Style="{StaticResource ModernTextBoxStyle}" 
                             Margin="0,0,0,15" 
                             Text="{Binding StartTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             />

                    <TextBlock Text="Дата прибытия" Style="{StaticResource LabelStyle}"/>
                    <DatePicker x:Name="EndDatePicker" 
                                Style="{StaticResource ModernDatePickerStyle}" 
                                Margin="0,0,0,15"
                                SelectedDate="{Binding EndDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Время прибытия (ЧЧ:ММ)" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="EndTimeTextBox" 
                             Style="{StaticResource ModernTextBoxStyle}" 
                             Margin="0,0,0,15" 
                             Text="{Binding EndTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             />

                    <Border Background="#E3F2FD"
                            CornerRadius="8"
                            Padding="15"
                            Margin="0,20,0,0">
                        <StackPanel>
                            <TextBlock Text="ℹ️ Формат времени"
                                       FontWeight="Bold"
                                       Foreground="#1E88E5"
                                       Margin="0,0,0,5"/>
                            <TextBlock Text="Время указывается в 24-часовом формате ЧЧ:ММ"
                                       FontSize="11"
                                       Foreground="#757575"/>
                            <TextBlock Text="Например: 23:55, 08:30, 14:45"
                                       FontSize="11"
                                       Foreground="#757575"
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,20,0,0">
            <Button Content="Отмена" 
                    Style="{StaticResource SecondaryButtonStyle}"
                    Width="100" Height="40"
                    Margin="0,0,10,0"
                    Click="CancelButton_Click"/>
            <Button Content="Сохранить" 
                    Style="{StaticResource PrimaryButtonStyle}"
                    Width="100" Height="40"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>