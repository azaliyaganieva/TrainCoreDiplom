<Window x:Class="TrainCoreDiplom.AdminWindows.ScheduleEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование расписания"
        Height="776" Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F7FA">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0"
                Background="#1E88E5"
                CornerRadius="8"
                Padding="15"
                Margin="0,0,0,20">
            <TextBlock Text="Данные рейса"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Форма - используем Border для CornerRadius и Padding -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="8"
                Padding="20">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <TextBlock Text="Поезд" 
                               FontWeight="SemiBold" 
                               Foreground="#1E88E5"
                               Margin="0,0,0,5"/>
                    <ComboBox x:Name="TrainComboBox" 
                              Style="{StaticResource ModernComboBoxStyle}" 
                              Margin="0,0,0,15"/>

                    <TextBlock Text="Маршрут" 
                               FontWeight="SemiBold" 
                               Foreground="#1E88E5"
                               Margin="0,0,0,5"/>
                    <ComboBox x:Name="RouteComboBox" 
                              Style="{StaticResource ModernComboBoxStyle}" 
                              Margin="0,0,0,15"/>

                    <TextBlock Text="Дата отправления" 
                               FontWeight="SemiBold" 
                               Foreground="#1E88E5"
                               Margin="0,0,0,5"/>
                    <DatePicker x:Name="StartDatePicker" 
                                Style="{StaticResource ModernDatePickerStyle}" 
                                Margin="0,0,0,15"/>

                    <TextBlock Text="Время отправления (ЧЧ:ММ)" 
                               FontWeight="SemiBold" 
                               Foreground="#1E88E5"
                               Margin="0,0,0,5"/>
                    <TextBox x:Name="StartTimeTextBox" 
                             Style="{StaticResource ModernTextBoxStyle}" 
                             Margin="0,0,0,15" 
                             Text="00:00"/>

                    <TextBlock Text="Дата прибытия" 
                               FontWeight="SemiBold" 
                               Foreground="#1E88E5"
                               Margin="0,0,0,5"/>
                    <DatePicker x:Name="EndDatePicker" 
                                Style="{StaticResource ModernDatePickerStyle}" 
                                Margin="0,0,0,15"/>

                    <TextBlock Text="Время прибытия (ЧЧ:ММ)" 
                               FontWeight="SemiBold" 
                               Foreground="#1E88E5"
                               Margin="0,0,0,5"/>
                    <TextBox x:Name="EndTimeTextBox" 
                             Style="{StaticResource ModernTextBoxStyle}" 
                             Margin="0,0,0,15" 
                             Text="00:00"/>

                    <TextBlock Text="Примечание: время указывается в формате ЧЧ:ММ (например, 23:55)"
                               FontSize="11"
                               Foreground="#757575"
                               Margin="0,10,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,20,0,0">

            <Button Content="Отмена" 
                    Style="{StaticResource SecondaryButtonStyle}"
                    Width="100" Height="40"
                    Margin="0,0,10,0"
                    Click="CancelButton_Click"/>

            <Button Content="Сохранить" 
                    Style="{StaticResource PrimaryButtonStyle}"
                    Width="100" Height="40"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>