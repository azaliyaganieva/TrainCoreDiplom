<Window x:Class="TrainCoreDiplom.AdminWindows.WagonEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование вагона"
        Height="434" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F7FA">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0"
                Background="#1E88E5"
                CornerRadius="8"
                Padding="15"
                Margin="0,0,0,20">
            <TextBlock x:Name="TitleText"
                       Text="Данные вагона"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Форма -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="8"
                Padding="20">
            <StackPanel>
                <TextBlock Text="Номер вагона" 
                           FontWeight="SemiBold" 
                           Foreground="#1E88E5"
                           Margin="0,0,0,5"/>
                <TextBox x:Name="NumberTextBox" 
                         Style="{StaticResource ModernTextBoxStyle}" 
                         Margin="0,0,0,15"/>

                <TextBlock Text="Тип вагона" 
                           FontWeight="SemiBold" 
                           Foreground="#1E88E5"
                           Margin="0,0,0,5"/>
                <ComboBox x:Name="TypeComboBox" 
                          Style="{StaticResource ModernComboBoxStyle}" 
                          Margin="0,0,0,15"
                          DisplayMemberPath="Name_type_wagon"
                          SelectedValuePath="ID_type_wagon"/>
            </StackPanel>
        </Border>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,20,0,0">

            <Button Content="Отмена" 
                    Style="{StaticResource SecondaryButtonStyle}"
                    Width="100" Height="40"
                    Margin="0,0,10,0"
                    Click="CancelButton_Click"/>

            <Button Content="Сохранить" 
                    Style="{StaticResource PrimaryButtonStyle}"
                    Width="100" Height="40"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>