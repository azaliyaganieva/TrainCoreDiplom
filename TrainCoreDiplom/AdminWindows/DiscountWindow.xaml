<Window x:Class="TrainCoreDiplom.AdminWindows.DiscountWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Скидка"
        Height="509" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="Настройка скидки"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="#1E88E5"
                   Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Название скидки" Margin="0,0,0,5"/>
            <TextBox x:Name="NameTextBox" Style="{StaticResource ModernTextBoxStyle}" Margin="0,0,0,15"/>

            <TextBlock Text="Тип скидки" Margin="0,0,0,5"/>
            <ComboBox x:Name="TypeComboBox" Style="{StaticResource ModernComboBoxStyle}" Margin="0,0,0,15">
                <ComboBoxItem Content="Процентная" IsSelected="True"/>
                <ComboBoxItem Content="Фиксированная"/>
            </ComboBox>

            <TextBlock Text="Размер скидки" Margin="0,0,0,5"/>
            <TextBox x:Name="ValueTextBox" Style="{StaticResource ModernTextBoxStyle}" Margin="0,0,0,15"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Действует с" Margin="0,0,5,5"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="Действует по" Margin="5,0,0,5"/>

                <DatePicker Grid.Row="1" Grid.Column="0" x:Name="StartDatePicker" 
                           Style="{StaticResource ModernDatePickerStyle}" Margin="0,0,5,0"/>
                <DatePicker Grid.Row="1" Grid.Column="2" x:Name="EndDatePicker" 
                           Style="{StaticResource ModernDatePickerStyle}" Margin="5,0,0,0"/>
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Отмена" 
                    Style="{StaticResource SecondaryButtonStyle}"
                    Width="100" Height="40"
                    Margin="0,0,10,0"
                    Click="CancelButton_Click"/>
            <Button Content="Сохранить" 
                    Style="{StaticResource PrimaryButtonStyle}"
                    Width="100" Height="40"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>