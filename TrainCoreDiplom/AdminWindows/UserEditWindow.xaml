<Window x:Class="TrainCoreDiplom.AdminWindows.UserEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование пользователя"
        Height="539" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="Данные пользователя"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="#1E88E5"
                   Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Логин" Margin="0,0,0,5"/>
                <TextBox x:Name="LoginTextBox" Style="{StaticResource ModernTextBoxStyle}" Margin="0,0,0,15"/>

                <TextBlock Text="Email" Margin="0,0,0,5"/>
                <TextBox x:Name="EmailTextBox" Style="{StaticResource ModernTextBoxStyle}" Margin="0,0,0,15"/>

                <TextBlock Text="Пароль" Margin="0,0,0,5"/>
                <PasswordBox x:Name="PasswordBox" Style="{StaticResource ModernPasswordBoxStyle}" Margin="0,0,0,15"/>

                <TextBlock Text="Подтверждение пароля" Margin="0,0,0,5"/>
                <PasswordBox x:Name="ConfirmPasswordBox" Style="{StaticResource ModernPasswordBoxStyle}" Margin="0,0,0,15"/>

                <CheckBox x:Name="IsActiveCheckBox" Content="Активен" Margin="0,0,0,15" IsChecked="True"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Отмена" 
                    Style="{StaticResource SecondaryButtonStyle}"
                    Width="100" Height="40"
                    Margin="0,0,10,0"
                    Click="CancelButton_Click"/>
            <Button Content="Сохранить" 
                    Style="{StaticResource PrimaryButtonStyle}"
                    Width="100" Height="40"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>