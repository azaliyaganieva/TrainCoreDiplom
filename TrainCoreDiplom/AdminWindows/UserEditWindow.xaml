<Window x:Class="TrainCoreDiplom.AdminWindows.UserEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование пользователя"
        Height="600" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F7FA">

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1E88E5"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0"
                Background="#1E88E5"
                CornerRadius="8"
                Padding="15"
                Margin="0,0,0,20">
            <TextBlock x:Name="TitleText"
                       Text="Данные пользователя"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Форма с прокруткой -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Border Background="White"
                    CornerRadius="8"
                    Padding="20">
                <StackPanel>
                    <TextBlock Text="Логин" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="LoginTextBox" 
                             Style="{StaticResource ModernTextBoxStyle}" 
                             Margin="0,0,0,15"/>

                    <TextBlock Text="Email" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="EmailTextBox" 
                             Style="{StaticResource ModernTextBoxStyle}" 
                             Margin="0,0,0,15"/>

                    <TextBlock Text="Пароль" Style="{StaticResource LabelStyle}"/>
                    <PasswordBox x:Name="PasswordBox" 
                                 Style="{StaticResource ModernPasswordBoxStyle}" 
                                 Margin="0,0,0,15"/>

                    <TextBlock Text="Подтверждение пароля" Style="{StaticResource LabelStyle}"/>
                    <PasswordBox x:Name="ConfirmPasswordBox" 
                                 Style="{StaticResource ModernPasswordBoxStyle}" 
                                 Margin="0,0,0,15"/>

                    <CheckBox x:Name="IsActiveCheckBox" 
                              Content="Активен"
                              IsChecked="True"
                              Margin="0,5,0,0"
                              FontSize="12"/>

                    <Border Background="#E3F2FD"
                            CornerRadius="8"
                            Padding="15"
                            Margin="0,20,0,0">
                        <TextBlock Text="ℹ️ При редактировании существующего пользователя поля пароля недоступны"
                                   FontSize="11"
                                   Foreground="#1E88E5"
                                   TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,20,0,0">
            <Button Content="Отмена" 
                    Style="{StaticResource SecondaryButtonStyle}"
                    Width="100" Height="40"
                    Margin="0,0,10,0"
                    Click="CancelButton_Click"/>
            <Button Content="Сохранить" 
                    Style="{StaticResource PrimaryButtonStyle}"
                    Width="100" Height="40"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>