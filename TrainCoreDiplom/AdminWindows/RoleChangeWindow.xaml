<Window x:Class="TrainCoreDiplom.AdminWindows.RoleChangeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Смена роли"
        Height="450" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F7FA">

    <Window.Resources>
        <Style TargetType="RadioButton">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Foreground" Value="#333333"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0"
                Background="#1E88E5"
                CornerRadius="8"
                Padding="15"
                Margin="0,0,0,20">
            <TextBlock x:Name="TitleText"
                       Text="Выберите новую роль пользователя"
                       FontSize="16"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Выбор роли -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Border Background="White"
                    CornerRadius="8"
                    Padding="20">
                <StackPanel>
                    <RadioButton x:Name="AdminRadioButton" 
                                 Content="👑 Администратор (полный доступ)"
                                 GroupName="Role"
                                 Margin="0,0,0,15"
                                 Foreground="#1E88E5"
                                 FontWeight="SemiBold"/>

                    <RadioButton x:Name="ManagerRadioButton" 
                                 Content="📊 Менеджер (управление поездами)"
                                 GroupName="Role"
                                 Margin="0,0,0,15"
                                 Foreground="#FF9800"
                                 FontWeight="SemiBold"/>

                    <RadioButton x:Name="UserRadioButton" 
                                 Content="👤 Пользователь (только покупка билетов)"
                                 GroupName="Role"
                                 IsChecked="True"
                                 Foreground="#4CAF50"
                                 FontWeight="SemiBold"/>

                    <Border Background="#E3F2FD"
                            CornerRadius="8"
                            Padding="15"
                            Margin="0,20,0,0">
                        <StackPanel>
                            <TextBlock Text="⚠️ Внимание!"
                                       FontWeight="Bold"
                                       Foreground="#1E88E5"
                                       Margin="0,0,0,5"/>
                            <TextBlock Text="Изменение роли влияет на доступ пользователя к функциям системы"
                                       FontSize="11"
                                       Foreground="#757575"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,20,0,0">
            <Button Content="Отмена" 
                    Style="{StaticResource SecondaryButtonStyle}"
                    Width="100" Height="40"
                    Margin="0,0,10,0"
                    Click="CancelButton_Click"/>
            <Button Content="Сохранить" 
                    Style="{StaticResource PrimaryButtonStyle}"
                    Width="100" Height="40"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>