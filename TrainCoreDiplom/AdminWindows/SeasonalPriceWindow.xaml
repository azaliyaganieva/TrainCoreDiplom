<Window x:Class="TrainCoreDiplom.AdminWindows.SeasonalPriceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Сезонный коэффициент"
        Height="550" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F7FA">

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1E88E5"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0"
                Background="#1E88E5"
                CornerRadius="8"
                Padding="15"
                Margin="0,0,0,20">
            <TextBlock x:Name="TitleText"
                       Text="Настройка сезонного коэффициента"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Форма с прокруткой -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Border Background="White"
                    CornerRadius="8"
                    Padding="20">
                <StackPanel>
                    <TextBlock Text="Название сезона" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="SeasonTextBox" 
                             Style="{StaticResource ModernTextBoxStyle}" 
                             Margin="0,0,0,15"
                             />

                    <TextBlock Text="Коэффициент" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="CoeffTextBox" 
                             Style="{StaticResource ModernTextBoxStyle}" 
                             Margin="0,0,0,15" 
                             Text="1.0"/>

                    <TextBlock Text="Период действия" 
                               FontSize="14" 
                               FontWeight="SemiBold" 
                               Foreground="#1E88E5"
                               Margin="0,10,0,10"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" 
                                   Text="Дата начала" 
                                   Style="{StaticResource LabelStyle}"
                                   Margin="0,0,5,5"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" 
                                   Text="Дата окончания" 
                                   Style="{StaticResource LabelStyle}"
                                   Margin="5,0,0,5"/>

                        <DatePicker Grid.Row="1" Grid.Column="0" 
                                    x:Name="StartDatePicker" 
                                    Style="{StaticResource ModernDatePickerStyle}" 
                                    Margin="0,0,5,0"/>
                        <DatePicker Grid.Row="1" Grid.Column="2" 
                                    x:Name="EndDatePicker" 
                                    Style="{StaticResource ModernDatePickerStyle}" 
                                    Margin="5,0,0,0"/>
                    </Grid>

                    <Border Background="#E3F2FD"
                            CornerRadius="8"
                            Padding="10"
                            Margin="0,20,0,0">
                        <TextBlock Text="ℹ️ Коэффициент будет применяться к базовым ценам в указанный период"
                                   FontSize="11"
                                   Foreground="#1E88E5"
                                   TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,20,0,0">
            <Button Content="Отмена" 
                    Style="{StaticResource SecondaryButtonStyle}"
                    Width="100" Height="40"
                    Margin="0,0,10,0"
                    Click="CancelButton_Click"/>
            <Button Content="Сохранить" 
                    Style="{StaticResource PrimaryButtonStyle}"
                    Width="100" Height="40"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>