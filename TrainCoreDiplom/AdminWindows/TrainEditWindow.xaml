<Window x:Class="TrainCoreDiplom.AdminWindows.TrainEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование поезда"
        Height="434" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="Данные поезда"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="#1E88E5"
                   Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Номер поезда" Margin="0,0,0,5"/>
            <TextBox x:Name="NumberTextBox" Style="{StaticResource ModernTextBoxStyle}" Margin="0,0,0,15"/>

            <TextBlock Text="Название поезда" Margin="0,0,0,5"/>
            <TextBox x:Name="NameTextBox" Style="{StaticResource ModernTextBoxStyle}" Margin="0,0,0,15"/>

            <TextBlock Text="Тип поезда" Margin="0,0,0,5"/>
            <ComboBox x:Name="TypeComboBox" Style="{StaticResource ModernComboBoxStyle}" Margin="0,0,0,15"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Отмена" 
                    Style="{StaticResource SecondaryButtonStyle}"
                    Width="100" Height="40"
                    Margin="0,0,10,0"
                    Click="CancelButton_Click"/>
            <Button Content="Сохранить" 
                    Style="{StaticResource PrimaryButtonStyle}"
                    Width="100" Height="40"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>