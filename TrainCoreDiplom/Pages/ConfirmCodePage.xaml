<Page x:Class="TrainCoreDiplom.Pages.ConfirmCodePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Подтверждение кода"
      MaxHeight="600" MaxWidth="400"
      MinHeight="500" MinWidth="400"
      Background="#F5F7FA">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0"
                Background="White"
                CornerRadius="12"
                Padding="20"
                Margin="0,0,0,20">
            <TextBlock Text="Подтверждение кода"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#1E88E5"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Форма -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="12"
                Padding="30">
            <StackPanel VerticalAlignment="Center">
                <TextBlock x:Name="EmailInfoText"
                           Text="Код отправлен на email"
                           FontSize="14"
                           Foreground="#1E88E5"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <TextBlock Text="Введите код подтверждения"
                           FontSize="14"
                           Foreground="#757575"
                           Margin="0,0,0,10"
                           HorizontalAlignment="Center"/>

                <TextBox x:Name="CodeTextBox"
                         Style="{StaticResource ModernTextBoxStyle}"
                         MaxLength="6"
                         HorizontalAlignment="Center"
                         Width="200"
                         TextAlignment="Center"
                         FontSize="18"
                         FontWeight="Bold"
                         Margin="0,0,0,20"/>

                <Button x:Name="VerifyButton"
                        Content="Подтвердить"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Height="45"
                        Click="VerifyButton_Click"/>

                <Button x:Name="ResendButton"
                        Content="Отправить код повторно"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Height="40"
                        Margin="0,10,0,0"
                        Click="ResendButton_Click"/>
            </StackPanel>
        </Border>

        <!-- Кнопка назад -->
        <Button Grid.Row="2"
                Content="← Вернуться"
                Style="{StaticResource SecondaryButtonStyle}"
                Height="40"
                Margin="0,20,0,0"
                Click="BackButton_Click"/>
    </Grid>
</Page>