<Page x:Class="TrainCoreDiplom.Pages.TrainSearchPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:System="clr-namespace:System;assembly=mscorlib"
      Title="Поиск поездов"
      MaxHeight="1080" MaxWidth="1920"
      MinHeight="600" MinWidth="800">

    <Page.Resources>
        <!-- Стиль для карточки поезда -->
        <Style x:Key="TrainCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка с пользователем -->
        <Border Grid.Row="0" 
                Background="White"
                CornerRadius="12"
                Padding="20"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Логотип -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="TRAINCORE" 
                               FontSize="24" 
                               FontWeight="Bold"
                               Foreground="#1E88E5"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Информация о пользователе -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBlock Text="👤" FontSize="20" Margin="0,0,10,0"/>
                    <TextBlock x:Name="UserNameText" 
                               Text="Гость"
                               FontSize="16"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <Button Content="Выйти"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Height="35"
                            Padding="15,0"
                            Margin="20,0,0,0"
                            Click="LogoutButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Панель поиска -->
        <Border Grid.Row="1" 
                Background="White"
                CornerRadius="12"
                Padding="30"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Откуда -->
                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                    <TextBlock Text="Откуда"
                               FontSize="14"
                               Foreground="#757575"
                               Margin="0,0,0,5"/>
                    <ComboBox x:Name="FromStationComboBox"
                              Style="{StaticResource ModernComboBoxStyle}"
                              MinWidth="200"
                              DisplayMemberPath="Name_Station"/>
                </StackPanel>

                <!-- Кнопка смены направления -->
                <Button Grid.Column="1" 
                        Content="⇄"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Width="45"
                        Height="45"
                        Padding="0"
                        FontSize="20"
                        Margin="0,20,0,0"
                        Click="SwapStations_Click"/>

                <!-- Куда -->
                <StackPanel Grid.Column="2" Margin="20,0,20,0">
                    <TextBlock Text="Куда"
                               FontSize="14"
                               Foreground="#757575"
                               Margin="0,0,0,5"/>
                    <ComboBox x:Name="ToStationComboBox"
                              Style="{StaticResource ModernComboBoxStyle}"
                              MinWidth="200"
                              DisplayMemberPath="Name_Station"/>
                </StackPanel>

                <!-- Дата -->
                <StackPanel Grid.Column="3" Margin="0,0,20,0">
                    <TextBlock Text="Дата отправления"
               FontSize="14"
               Foreground="#757575"
               Margin="0,0,0,5"/>

                    
                    <DatePicker x:Name="DepartureDatePicker"
                Width="150"
                Height="35"
                SelectedDate="{x:Static System:DateTime.Today}"
                DisplayDateStart="{x:Static System:DateTime.Today}"
                Background="White"
                BorderBrush="#E0E0E0"
                BorderThickness="1"/>
                </StackPanel>

                <!-- Кнопка поиска -->
                <Button Grid.Column="4" 
                        x:Name="SearchButton"
                        Content="Найти поезда"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Height="45"
                        Width="150"
                        FontSize="14"
                        Click="SearchButton_Click"/>
            </Grid>
        </Border>

        <!-- Результаты поиска -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Заголовок результатов -->
            <TextBlock Grid.Row="0"
                       x:Name="ResultsTitle"
                       Text="Найденные поезда"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Margin="0,0,0,15"
                       Visibility="Collapsed"/>

            <!-- Список поездов -->
            <ScrollViewer Grid.Row="1" 
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="TrainsItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource TrainCardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Время отправления -->
                                    <StackPanel Grid.Row="0" Grid.Column="0" Width="100">
                                        <TextBlock Text="{Binding DepartureTime}"
                                                   FontSize="24"
                                                   FontWeight="Bold"
                                                   Foreground="#1E88E5"/>
                                        <TextBlock Text="{Binding DepartureStation}"
                                                   FontSize="12"
                                                   Foreground="#757575"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <!-- Маршрут -->
                                    <Grid Grid.Row="0" Grid.Column="1" Margin="20,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Text="{Binding TrainName}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"/>

                                        <TextBlock Grid.Row="1"
                                                   Text="{Binding Duration}"
                                                   FontSize="12"
                                                   Foreground="#757575"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,5,0,0"/>
                                    </Grid>

                                    <!-- Время прибытия -->
                                    <StackPanel Grid.Row="0" Grid.Column="2" Width="100" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding ArrivalTime}"
                                                   FontSize="24"
                                                   FontWeight="Bold"
                                                   Foreground="#43A047"
                                                   HorizontalAlignment="Right"/>
                                        <TextBlock Text="{Binding ArrivalStation}"
                                                   FontSize="12"
                                                   Foreground="#757575"
                                                   TextWrapping="Wrap"
                                                   HorizontalAlignment="Right"/>
                                    </StackPanel>

                                    <!-- Нижняя строка -->
                                    <StackPanel Grid.Row="1" 
                                                Grid.ColumnSpan="3"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                Margin="0,15,0,0">

                                        <Border Background="#E3F2FD"
                                                CornerRadius="4"
                                                Padding="8,4"
                                                Margin="0,0,10,0">
                                            <TextBlock Text="{Binding FreeSeats}" 
                                                       Foreground="#1E88E5"
                                                       FontSize="12"/>
                                        </Border>

                                        <TextBlock Text="{Binding Price}"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   Foreground="#43A047"
                                                   Margin="0,0,15,0"/>

                                        <Button Content="Выбрать места"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                Height="35"
                                                Padding="20,0"
                                                Tag="{Binding ScheduleId}"
                                                Click="SelectTrain_Click"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>