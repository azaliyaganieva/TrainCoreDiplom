<Page x:Class="TrainCoreDiplom.Pages.ReturnTicketPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Возврат билета"
      MaxHeight="1080" MaxWidth="1920"
      MinHeight="600" MinWidth="800">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0"
                Background="White"
                CornerRadius="12"
                Padding="20"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Возврат билета"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#1E88E5"/>
                    <TextBlock Text="Выберите билет для возврата"
                               FontSize="14"
                               Foreground="#757575"
                               Margin="0,5,0,0"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Назад"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Height="40"
                        Width="100"
                        Click="BackButton_Click"/>
            </Grid>
        </Border>

        <!-- Основная часть -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Поиск билета -->
                <Border Background="White"
                        CornerRadius="12"
                        Padding="20"
                        Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Номер билета:"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>

                        <TextBox Grid.Column="1"
                                 x:Name="TicketNumberTextBox"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 Width="200"
                                 HorizontalAlignment="Left"/>

                        <Button Grid.Column="2"
                                Content="Найти"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Height="40"
                                Width="100"
                                Margin="10,0,0,0"
                                Click="FindTicket_Click"/>
                    </Grid>
                </Border>

                <!-- Информация о билете (появляется после поиска) -->
                <Border x:Name="TicketInfoBorder"
                        Background="White"
                        CornerRadius="12"
                        Padding="20"
                        Margin="0,0,0,20"
                        Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Информация о билете"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#1E88E5"
                                   Margin="0,0,0,15"/>

                        <Grid Grid.Row="1" Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Номер билета:" Foreground="#757575"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TicketNumberInfoText" FontWeight="SemiBold"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Поезд:" Foreground="#757575" Margin="0,10,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TrainInfoText" Margin="0,10,0,0"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Маршрут:" Foreground="#757575" Margin="0,10,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="RouteInfoText" Margin="0,10,0,0"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Дата отправления:" Foreground="#757575" Margin="0,10,0,0"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="DateInfoText" Margin="0,10,0,0"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Стоимость:" Foreground="#757575" Margin="0,10,0,0"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" x:Name="PriceInfoText" Foreground="#43A047" FontWeight="Bold" Margin="0,10,0,0"/>
                        </Grid>

                        <!-- Сумма возврата -->
                        <Border Grid.Row="2"
                                Background="#FFF3E0"
                                CornerRadius="8"
                                Padding="15"
                                Margin="0,0,0,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Сумма к возврату"
                                               FontSize="14"
                                               Foreground="#E65100"/>
                                    <TextBlock x:Name="RefundAmountText"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               Foreground="#E65100"/>
                                </StackPanel>

                                <TextBlock Grid.Column="1"
                                           Text="⚠️"
                                           FontSize="32"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Кнопка возврата -->
                        <Button Grid.Row="3"
                                x:Name="ReturnButton"
                                Content="Оформить возврат"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Height="50"
                                FontSize="16"
                                Background="#E53935"
                                Click="ReturnButton_Click"/>
                    </Grid>
                </Border>

                <!-- Правила возврата -->
                <Border Background="White"
                        CornerRadius="12"
                        Padding="20">
                    <StackPanel>
                        <TextBlock Text="Правила возврата"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#1E88E5"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="• При возврате более чем за 24 часа до отправления - возвращается 100% стоимости"
                                   TextWrapping="Wrap"
                                   Margin="0,5"/>
                        <TextBlock Text="• При возврате за 8-24 часа до отправления - возвращается 50% стоимости"
                                   TextWrapping="Wrap"
                                   Margin="0,5"/>
                        <TextBlock Text="• При возврате менее чем за 8 часов до отправления - возврат не производится"
                                   TextWrapping="Wrap"
                                   Margin="0,5"/>
                        <TextBlock Text="• Сбор за возврат билета - 500 ₽"
                                   TextWrapping="Wrap"
                                   Margin="0,5"
                                   FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>