<Page x:Class="TrainCoreDiplom.Pages.ForgotPasswordPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Восстановление пароля"
      MaxHeight="600" MaxWidth="400"
      MinHeight="500" MinWidth="400"
      Background="#F5F7FA">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0"
                Background="White"
                CornerRadius="12"
                Padding="20"
                Margin="0,0,0,20">
            <TextBlock Text="Восстановление пароля"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#1E88E5"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Форма -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="12"
                Padding="30">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Введите ваш email"
                           FontSize="14"
                           Foreground="#757575"
                           Margin="0,0,0,10"/>
                <TextBox x:Name="EmailTextBox"
                         Style="{StaticResource ModernTextBoxStyle}"
                         Margin="0,0,0,20"/>

                <TextBlock Text="Введите номер паспорта"
                           FontSize="14"
                           Foreground="#757575"
                           Margin="0,0,0,10"/>
                <TextBox x:Name="PassportTextBox"
                         Style="{StaticResource ModernTextBoxStyle}"
                         Margin="0,0,0,30"/>

                <Button x:Name="ResetButton"
                        Content="Восстановить пароль"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Height="45"
                        Click="ResetButton_Click"/>
            </StackPanel>
        </Border>

        <!-- Кнопка назад -->
        <Button Grid.Row="2"
                Content="← Вернуться к входу"
                Style="{StaticResource SecondaryButtonStyle}"
                Height="40"
                Margin="0,20,0,0"
                Click="BackButton_Click"/>
    </Grid>
</Page>