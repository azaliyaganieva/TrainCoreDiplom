<Page x:Class="TrainCoreDiplom.Pages.PaymentPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Оплата билета"
      MaxHeight="1080" MaxWidth="1920"
      MinHeight="600" MinWidth="800"
      Background="#F5F7FA">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" 
                Background="White"
                CornerRadius="12"
                Padding="20"
                Margin="0,0,0,20">
            <TextBlock Text="Оплата билета"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="#1E88E5"/>
        </Border>

        <!-- Основная часть -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Информация о заказе -->
                <Border Background="White"
                        CornerRadius="12"
                        Padding="20"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Информация о заказе"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#1E88E5"
                                   Margin="0,0,0,15"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Билет:" Foreground="#757575"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TicketNumberText" FontWeight="SemiBold"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Маршрут:" Foreground="#757575" Margin="0,10,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="RouteText" Margin="0,10,0,0"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Пассажир:" Foreground="#757575" Margin="0,10,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="PassengerText" Margin="0,10,0,0"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Сумма:" Foreground="#757575" Margin="0,10,0,0"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="PriceText" 
                                       Foreground="#43A047" FontWeight="Bold" FontSize="18" Margin="0,10,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Способ оплаты -->
                <Border Background="White"
                        CornerRadius="12"
                        Padding="20"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Способ оплаты"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#1E88E5"
                                   Margin="0,0,0,15"/>

                        <RadioButton x:Name="CardRadioButton" 
                                     Content="Банковская карта" 
                                     IsChecked="True"
                                     Margin="0,5"/>
                        <RadioButton x:Name="CashRadioButton" 
                                     Content="Наличные в кассе" 
                                     Margin="0,5"/>
                        <RadioButton x:Name="OnlineRadioButton" 
                                     Content="Электронный кошелек" 
                                     Margin="0,5"/>
                    </StackPanel>
                </Border>

                <!-- Данные карты (показываются если выбрана карта) -->
                <Border x:Name="CardDetailsBorder"
                        Background="White"
                        CornerRadius="12"
                        Padding="20"
                        Margin="0,0,0,20"
                        Visibility="Visible">
                    <StackPanel>
                        <TextBlock Text="Данные карты"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#1E88E5"
                                   Margin="0,0,0,15"/>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Номер карты:" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1" 
                                     x:Name="CardNumberTextBox"
                                     Style="{StaticResource ModernTextBoxStyle}"
                                     Margin="0,0,0,5"
                                     MaxLength="19"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Срок:" VerticalAlignment="Center"/>
                            <Grid Grid.Row="1" Grid.Column="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" 
                                         x:Name="MonthTextBox"
                                         Style="{StaticResource ModernTextBoxStyle}"
                                         Margin="0,0,5,5"
                                         MaxLength="2"/>
                                <TextBlock Grid.Column="1" Text="/" Margin="5,0" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="2" 
                                         x:Name="YearTextBox"
                                         Style="{StaticResource ModernTextBoxStyle}"
                                         Margin="5,0,0,5"
                                         MaxLength="2"/>
                            </Grid>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="CVV:" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="2" Grid.Column="1" 
                                     x:Name="CvvTextBox"
                                     Style="{StaticResource ModernTextBoxStyle}"
                                     Margin="0,0,0,5"
                                     MaxLength="3"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Информация о безопасности -->
                <Border Background="#E3F2FD"
                        CornerRadius="12"
                        Padding="15">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔒" FontSize="24" Margin="0,0,15,0"/>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="#1E88E5"
                                   FontSize="12">
                            Ваши платежные данные защищены. Оплата производится через защищенное соединение.
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Нижняя панель -->
        <Border Grid.Row="2" 
                Background="White"
                CornerRadius="12"
                Padding="20"
                Margin="0,20,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Нажимая 'Оплатить', вы соглашаетесь с условиями"
                           Foreground="#757575"
                           FontSize="12"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Назад"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Height="45"
                            Width="120"
                            Margin="0,0,10,0"
                            Click="BackButton_Click"/>

                    <Button x:Name="PayButton"
                            Content="Оплатить"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Height="45"
                            Width="150"
                            Click="PayButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>