<Page x:Class="TrainCoreDiplom.Pages.UserProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Личный кабинет"
      MaxHeight="1080" MaxWidth="1920"
      MinHeight="600" MinWidth="800">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0"
                Background="White"
                CornerRadius="12"
                Padding="20"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="👤"
                           FontSize="40"
                           Margin="0,0,20,0"/>

                <StackPanel Grid.Column="1">
                    <TextBlock x:Name="UserNameText"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#1E88E5"/>
                    <TextBlock x:Name="UserEmailText"
                               FontSize="14"
                               Foreground="#757575"/>
                </StackPanel>

                <Button Grid.Column="2"
                        Content="Выйти"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Height="40"
                        Width="100"
                        Click="LogoutButton_Click"/>
            </Grid>
        </Border>

        <!-- Вкладки -->
        <TabControl Grid.Row="1"
                    Background="Transparent"
                    BorderThickness="0">

            <!-- Мои билеты -->
            <TabItem Header="Мои билеты">
                <Border Background="White"
                        CornerRadius="12"
                        Padding="20"
                        Margin="0,10,0,0">
                    <DataGrid x:Name="TicketsGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              RowHeight="40"
                              Background="Transparent">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Дата покупки" 
                                                Binding="{Binding BuyDate}"
                                                Width="120"/>
                            <DataGridTextColumn Header="Поезд" 
                                                Binding="{Binding TrainName}"
                                                Width="150"/>
                            <DataGridTextColumn Header="Маршрут" 
                                                Binding="{Binding Route}"
                                                Width="200"/>
                            <DataGridTextColumn Header="Вагон/Место" 
                                                Binding="{Binding Seat}"
                                                Width="120"/>
                            <DataGridTextColumn Header="Статус" 
                                                Binding="{Binding Status}"
                                                Width="100"/>
                            <DataGridTemplateColumn Header="Действия" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="👁"
                                                Width="30"
                                                Height="30"
                                                Click="ViewTicket_Click"
                                                Tag="{Binding TicketId}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>

            <!-- Настройки -->
            <TabItem Header="Настройки">
                <Border Background="White"
                        CornerRadius="12"
                        Padding="20"
                        Margin="0,10,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Личные данные"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#1E88E5"
                                   Margin="0,0,0,20"/>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="300"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Имя:" Margin="10"/>
                            <TextBox Grid.Row="0" Grid.Column="1" 
                                     x:Name="FirstNameTextBox"
                                     Style="{StaticResource ModernTextBoxStyle}"
                                     Width="250"
                                     Margin="5"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Фамилия:" Margin="10"/>
                            <TextBox Grid.Row="1" Grid.Column="1" 
                                     x:Name="LastNameTextBox"
                                     Style="{StaticResource ModernTextBoxStyle}"
                                     Width="250"
                                     Margin="5"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Email:" Margin="10"/>
                            <TextBox Grid.Row="2" Grid.Column="1" 
                                     x:Name="EmailTextBox"
                                     Style="{StaticResource ModernTextBoxStyle}"
                                     Width="250"
                                     Margin="5"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Телефон:" Margin="10"/>
                            <TextBox Grid.Row="3" Grid.Column="1" 
                                     x:Name="PhoneTextBox"
                                     Style="{StaticResource ModernTextBoxStyle}"
                                     Width="250"
                                     Margin="5"/>
                        </Grid>

                        <Button Grid.Row="2"
                                Content="Сохранить изменения"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Height="40"
                                Width="200"
                                Margin="0,30,0,0"
                                HorizontalAlignment="Left"
                                Click="SaveSettings_Click"/>
                    </Grid>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</Page>