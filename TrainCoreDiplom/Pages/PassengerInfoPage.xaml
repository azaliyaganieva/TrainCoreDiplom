<Page x:Class="TrainCoreDiplom.Pages.PassengerInfoPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Данные пассажира"
      MaxHeight="1080" MaxWidth="1920"
      MinHeight="600" MinWidth="800">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Шапка с информацией о поездке -->
        <Border Grid.Row="0" 
                Background="White"
                CornerRadius="12"
                Padding="20"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="TrainInfoText" 
                               FontSize="20" 
                               FontWeight="Bold"
                               Foreground="#1E88E5"/>
                    <TextBlock x:Name="RouteInfoText" 
                               FontSize="14"
                               Margin="0,5,0,0"/>
                    <TextBlock x:Name="DateInfoText" 
                               FontSize="12"
                               Foreground="#757575"
                               Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <TextBlock x:Name="SeatInfoText" 
                               FontSize="14"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Right"/>
                    <TextBlock x:Name="PriceText" 
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#43A047"
                               HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Форма ввода данных -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="12"
                Padding="30">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Введите данные пассажира"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#1E88E5"
                           Margin="0,0,0,20"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Фамилия -->
                        <TextBlock Grid.Row="0" Grid.Column="0" 
                                   Text="Фамилия *" 
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"/>
                        <TextBox Grid.Row="0" Grid.Column="1" 
                                 x:Name="LastNameTextBox"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 Margin="0,0,0,10"
                                 TextChanged="FieldChanged"/>

                        <!-- Имя -->
                        <TextBlock Grid.Row="1" Grid.Column="0" 
                                   Text="Имя *" 
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"/>
                        <TextBox Grid.Row="1" Grid.Column="1" 
                                 x:Name="FirstNameTextBox"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 Margin="0,0,0,10"
                                 TextChanged="FieldChanged"/>

                        <!-- Отчество -->
                        <TextBlock Grid.Row="2" Grid.Column="0" 
                                   Text="Отчество" 
                                   VerticalAlignment="Center"/>
                        <TextBox Grid.Row="2" Grid.Column="1" 
                                 x:Name="MiddleNameTextBox"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 Margin="0,0,0,10"/>

                        <!-- Паспорт -->
                        <TextBlock Grid.Row="3" Grid.Column="0" 
                                   Text="Номер паспорта *" 
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"/>
                        <TextBox Grid.Row="3" Grid.Column="1" 
                                 x:Name="PassportTextBox"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 Margin="0,0,0,10"
                                 TextChanged="FieldChanged"/>

                        <!-- Телефон -->
                        <TextBlock Grid.Row="4" Grid.Column="0" 
                                   Text="Телефон" 
                                   VerticalAlignment="Center"/>
                        <TextBox Grid.Row="4" Grid.Column="1" 
                                 x:Name="PhoneTextBox"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 Margin="0,0,0,10"/>

                        <!-- Email -->
                        <TextBlock Grid.Row="5" Grid.Column="0" 
                                   Text="Email" 
                                   VerticalAlignment="Center"/>
                        <TextBox Grid.Row="5" Grid.Column="1" 
                                 x:Name="EmailTextBox"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 Margin="0,0,0,10"/>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Нижняя панель -->
        <Border Grid.Row="2" 
                Background="White"
                CornerRadius="12"
                Padding="20"
                Margin="0,20,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="* Обязательные поля"
                           Foreground="#757575"
                           FontStyle="Italic"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Назад"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Height="40"
                            Width="100"
                            Margin="0,0,10,0"
                            Click="BackButton_Click"/>

                    <Button x:Name="ContinueButton"
                            Content="Продолжить"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Height="40"
                            Width="150"
                            IsEnabled="False"
                            Click="ContinueButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>